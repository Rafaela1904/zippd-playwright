{
  "compilerOptions": {
    "types": ["node", "@playwright/test"],
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["pages/*"],
      "@tests/*": ["tests/*"],
      "@helpers/*": ["helpers/*"]
    }
  },
  "include": ["tests/**/*.ts", "pages/**/*.ts", "helpers/**/*.ts"]
}